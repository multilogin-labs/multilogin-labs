# Multilogin X API — get automation token from dashboard or signin
MULTILOGIN_TOKEN=your_bearer_token_here
MULTILOGIN_REFRESH_TOKEN=optional_refresh_token

# Sign-in (optional — for scripts/python/signin.py)
MULTILOGIN_EMAIL=
MULTILOGIN_PASSWORD=

# Profile UUIDs from Multilogin app (folder + profile required for start)
MULTILOGIN_FOLDER_ID=your_folder_uuid_here
MULTILOGIN_PROFILE_ID=your_profile_uuid_here

# Launcher (local MLX agent — app must be running)
MULTILOGIN_LAUNCHER_URL=https://launcher.mlx.yt:45001

# Automation: selenium | puppeteer | playwright
MULTILOGIN_AUTOMATION_TYPE=playwright
MULTILOGIN_DEBUG_PORT=35000
