{
  "_comment": "Algolia DocSearch application JSON. Submit at https://docsearch.algolia.com/apply once GitHub Pages is live.",
  "index_name": "multilogin-labs",
  "start_urls": ["https://multilogin-labs.github.io/multilogin-labs/"],
  "sitemap_urls": [
    "https://multilogin-labs.github.io/multilogin-labs/sitemap.xml"
  ],
  "stop_urls": [],
  "selectors": {
    "lvl0": {
      "selector": "h1",
      "global": true
    },
    "lvl1": "h2",
    "lvl2": "h3",
    "lvl3": "h4",
    "lvl4": "h5",
    "lvl5": "h6",
    "text": "p, li, td, code"
  },
  "min_indexed_level": 0,
  "custom_settings": {
    "attributesForFaceting": ["language", "category"],
    "attributeForDistinct": "url",
    "distinct": true
  },
  "scrape_start_urls": true,
  "strict_redirects": false
}
