{
  "name": "multilogin-labs",
  "version": "1.0.0",
  "description": "Open-source Multilogin automation scripts, guides, and MMO resources",
  "type": "module",
  "private": true,
  "scripts": {
    "api:launch": "node scripts/api/launch-profile.mjs",
    "playwright:connect": "node scripts/playwright/connect-profile.mjs",
    "puppeteer:connect": "node scripts/puppeteer/connect-profile.mjs",
    "selenium:connect": "node scripts/selenium/connect-profile.mjs",
    "api:stop": "node scripts/api/stop-profile.mjs",
    "proxy:check": "node tools/proxy-check.mjs",
    "plan": "node tools/plan-calculator.mjs",
    "api:search": "node tools/api-search.mjs",
    "sitemap": "node tools/generate_sitemap.mjs",
    "upgrade": "bash tools/upgrade_all.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "optionalDependencies": {
    "playwright": "^1.49.0",
    "puppeteer-core": "^23.0.0"
  },
  "keywords": [
    "multilogin",
    "antidetect",
    "multi-account",
    "cloud-phone",
    "playwright",
    "puppeteer",
    "mmo"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/multilogin-labs/multilogin-labs.git"
  }
}
